# Merchants – Create Merchant
# Smoke tests for POST /merchants.
#
# Admin-only endpoint. Run the helper login requests below to obtain a fresh
# token, then paste it (as "Bearer <token>") into @adminToken above.

@baseUrl = http://localhost:8001/api/v1

# Paste fresh tokens here (use helper login requests below).
# These placeholder values are expired local-dev tokens from seed data — never real credentials.
