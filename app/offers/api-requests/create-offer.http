### Get a token for testing (user)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@clicknback.com",
  "password": "Str0ng!Pass"
}

### 201 – Happy path: create a percent offer (admin)
POST {{baseUrl}}/offers
Authorization: {{adminToken}}
Content-Type: application/json

{
  "merchant_id": "a9b0c1d2-e3f4-4a5b-6c7d-8e9f0a1b2c3d",
  "cashback_type": "percent",
  "cashback_value": 10,
  "start_date": "2026-12-01",
  "end_date": "2026-12-31",
  "monthly_cap": 50
}

### 201 – Happy path: create a fixed offer (admin)
POST {{baseUrl}}/offers
Authorization: {{adminToken}}
Content-Type: application/json

{
  "merchant_id": "f8a9b0c1-d2e3-4f4a-5b6c-7d8e9f0a1b2c",
  "cashback_type": "fixed",
  "cashback_value": 5.00,
  "start_date": "2026-04-01",
  "end_date": "2026-09-30",
  "monthly_cap": 20
}

### 400 – Sad path: invalid cashback value (percent out of range)
POST {{baseUrl}}/offers
Authorization: {{adminToken}}
Content-Type: application/json

{
  "merchant_id": "f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c",
  "cashback_type": "percent",
  "cashback_value": 150,
  "start_date": "2026-03-01",
  "end_date": "2026-12-31",
  "monthly_cap": 50
}

### 400 – Sad path: start date is in the past
POST {{baseUrl}}/offers
Authorization: {{adminToken}}
Content-Type: application/json

{
  "merchant_id": "f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c",
  "cashback_type": "percent",
  "cashback_value": 10,
  "start_date": "2025-01-01",
  "end_date": "2026-12-31",
  "monthly_cap": 50
}

### 400 – Sad path: end date before start date
POST {{baseUrl}}/offers
Authorization: {{adminToken}}
Content-Type: application/json

{
  "merchant_id": "f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c",
  "cashback_type": "percent",
  "cashback_value": 10,
  "start_date": "2026-12-31",
  "end_date": "2026-06-01",
  "monthly_cap": 50
}

