### Sad path: unsupported currency (422 Unprocessable Content — UNSUPPORTED_CURRENCY)
# Only EUR is accepted. USD and other currencies are rejected by the currency policy.
POST {{baseUrl}}/purchases
Authorization: {{userToken}}
Content-Type: application/json

{
  "external_id": "txn_smoke_011",
  "user_id": "b7e2c1a2-4f3a-4e2b-9c1a-8d2e3f4b5c6d",
  "merchant_id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
  "amount": 50.00,
  "currency": "USD"
}
