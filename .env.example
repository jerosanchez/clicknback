# This file is provided for local development only.
# Copy this file to `.env` and adjust values as needed, or leave the default values.

# --- Production secrets strategy
#
# In production, a `.env` file with real values is placed manually on the VPS at
# /home/clicknback/app/.env, owned by the deploy user, with permissions set to
# chmod 600. It is never committed to the repository.
#
# The CD pipeline never reads, writes, or references this file. It only pulls the
# new image and runs `docker compose up`. Docker Compose reads `.env` from the
# deploy directory at startup — no CI involvement.
#
# Application secrets (DATABASE_URL, OAUTH_HASH_KEY, etc.) never enter GitHub.
# GitHub Secrets are reserved for pipeline credentials only (VPS_HOST, VPS_USER,
# VPS_SSH_KEY). See docs/design/deployment-plan.md Section 8 for the full strategy.

# --- Database

POSTGRES_IMAGE=postgres:15

POSTGRES_HOST=localhost
# POSTGRES_HOST=clicknback-db
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# --- Security

OAUTH_HASH_KEY=7bdb4bcf0b01f00ca206693965b29145611d9419563630525dc848024c38fc08
OAUTH_ALGORITHM=HS256
OAUTH_TOKEN_TTL= 720  # Token time-to-live (TTL) in minutes: 12 hours

# --- Logging

LOG_LEVEL=INFO

# --- Application

MAX_CASHBACK_PERCENTAGE=20

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# --- Purchase confirmation background job
#
# How often (in seconds) the verification job runs.
PURCHASE_CONFIRMATION_INTERVAL_SECONDS=60
# How many job cycles a purchase at the rejection merchant survives before being rejected.
PURCHASE_MAX_VERIFICATION_ATTEMPTS=3
# UUID of the merchant whose purchases are always rejected (set in seeds/all.sql).
# Leave empty to disable rejection simulation.
REJECTION_MERCHANT_ID=f0000000-0000-0000-0000-000000000001

# --- Docker network

DOCKER_NETWORK_NAME=clicknback-nw

# --- Application settings

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Container

APP_PORT=8001
APP_IMAGE=ghcr.io/jerosanchez/clicknback:latest
